  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login status ok', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 400, 401]);",
                  "});",
                  "",
                  "var json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}",
                  "",
                  "if (json && json.data && json.data.utilisateur_id) {",
                  "  pm.collectionVariables.set('userId', String(json.data.utilisateur_id));",
                  "}",
                  "",
                  "if (json && json.data && json.data.challenge === '2fa_required') {",
                  "  pm.collectionVariables.set('twoFactorUserId', String(json.data.utilisateur_id || ''));",
                  "  pm.collectionVariables.set('twoFactorCode', String(json.data.code_demo || ''));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"mot_de_passe\": \"{{loginPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Connexion utilisateur. Si 2FA active, le code demo est stocke dans les variables de collection."
          },
          "response": []
        },
